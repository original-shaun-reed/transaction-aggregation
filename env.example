# ═══════════════════════════════════════════════════════════════
# .env.example — Transaction Aggregator
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is in .gitignore — never commit real secrets.
# ═══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transaction_aggregator
DB_USER=transaction_aggregator
DB_PASSWORD=transaction_aggregator_secret


# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret


# ─────────────────────────────────────────
# Kafka
# ─────────────────────────────────────────
# Local dev: localhost:9092
# AWS MSK:   boot-xxxx.kafka.eu-west-1.amazonaws.com:9098
KAFKA_BOOTSTRAP_SERVERS=localhost:9092


# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Must be at least 256 bits (32+ characters).
# Generate: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-min-256-bits-change-in-prod


# ─────────────────────────────────────────
# Webhook
# ─────────────────────────────────────────
# Shared HMAC secret between mock-sources and ingestor-service.
# Generate: openssl rand -hex 32
INGESTOR_WEBHOOK_SECRET=dev-webhook-secret-min-256-bits-change-in-prod
INGESTOR_WEBHOOK_URL=http://localhost:8082/api/internal/webhook/payment


# ─────────────────────────────────────────
# ML Classifier (optional)
# ─────────────────────────────────────────
# Leave blank to use rules-engine fallback only.
ML_CLASSIFIER_URL=


# ─────────────────────────────────────────
# AWS (prod only — leave blank for local dev)
# ─────────────────────────────────────────
AWS_REGION=
AWS_ACCOUNT_ID=

# MSK cluster ARN (used by IAM auth in prod Kafka config)
MSK_CLUSTER_ARN=

# RDS endpoint (replaces DB_HOST in prod)
RDS_ENDPOINT=

# ElastiCache endpoint (replaces REDIS_HOST in prod)
ELASTICACHE_ENDPOINT=


# ─────────────────────────────────────────
# Spring profiles
# ─────────────────────────────────────────
# Options: dev | prod
SPRING_PROFILES_ACTIVE=dev


# ─────────────────────────────────────────
# Service ports (override if clashing locally)
# ─────────────────────────────────────────
MOCK_SOURCES_PORT=8081
INGESTOR_PORT=8082
PROCESSING_PORT=8083
API_PORT=8080
KAFKA_UI_PORT=8090
PGADMIN_PORT=8091